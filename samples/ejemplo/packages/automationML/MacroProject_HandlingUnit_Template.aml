    </Attribute>
    <Attribute Name="Align centered" AttributeDataType="xs:boolean">
     <DefaultValue>true</DefaultValue>
     <Value>true</Value>
    </Attribute>
    <Attribute Name="Align bottom" AttributeDataType="xs:boolean">
     <DefaultValue>true</DefaultValue>
